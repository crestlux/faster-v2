if [ -n "${BASH_SOURCE[0]-}" ]; then
    ENV_FILE="${BASH_SOURCE[0]}"
elif [ -n "${ZSH_VERSION-}" ]; then
    ENV_FILE="${(%):-%N}"
else
    ENV_FILE="$0"
fi

ENV_ROOT="$(cd "$(dirname "$ENV_FILE")" && pwd)"

if [ -n "${CONDA_PREFIX:-}" ]; then
    echo "Using active conda environment: $CONDA_PREFIX"
elif [ -f "$ENV_ROOT/.venv/bin/activate" ]; then
    source "$ENV_ROOT/.venv/bin/activate"
else
    echo "ERROR: Could not find $ENV_ROOT/.venv/bin/activate and no conda environment is active" >&2
    return 1 2>/dev/null || exit 1
fi

export PYTHONPATH="${ENV_ROOT}${PYTHONPATH:+:$PYTHONPATH}"

export MUJOCO_GL=egl
export DISPLAY=
export SITE_PACKAGES=$(python -c "import site; print(site.getsitepackages()[0])")
export PATH="$SITE_PACKAGES/nvidia/cuda_nvcc/bin:$PATH"

export LD_LIBRARY_PATH="$SITE_PACKAGES/nvidia/cuda_runtime/lib:$SITE_PACKAGES/nvidia/cudnn/lib:$LD_LIBRARY_PATH"
export CPATH="$HOME/.local/include${CPATH:+:$CPATH}"
export C_INCLUDE_PATH="$HOME/.local/include${C_INCLUDE_PATH:+:$C_INCLUDE_PATH}"
export CPLUS_INCLUDE_PATH="$HOME/.local/include${CPLUS_INCLUDE_PATH:+:$CPLUS_INCLUDE_PATH}"

export CFLAGS="-DGLEW_NO_GLU ${CFLAGS:-}"
export CXXFLAGS="-DGLEW_NO_GLU ${CXXFLAGS:-}"

export HYDRA_FULL_ERROR=1
export LD_LIBRARY_PATH="$LD_LIBRARY_PATH:/usr/lib/nvidia:$HOME/.mujoco/mujoco210/bin:$HOME/.local/lib64"
export PATH="$PATH:$HOME/.mujoco/mujoco210/bin"
# export XLA_PYTHON_CLIENT_PREALLOCATE=false

if [[ -d /usr/local/cuda/bin ]]; then
    export PATH=/usr/local/cuda/bin:$PATH
    export XLA_FLAGS=--xla_gpu_cuda_data_dir=/usr/local/cuda
fi

export ROBOMIMIC_DATASETS_PATH="${ROBOMIMIC_DATASETS_PATH:-$ENV_ROOT/datasets/robomimic}"

export JAX_PLATFORMS=cuda
export PYTHON_DOTENV_DISABLED=1
